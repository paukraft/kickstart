{
  "name": "@kickstart/desktop",
  "productName": "Kickstart",
  "version": "0.1.5",
  "description": "Desktop launcher for development projects and durable terminal workflows.",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "private": true,
  "homepage": "https://github.com/paukraft/kickstart",
  "repository": {
    "type": "git",
    "url": "https://github.com/paukraft/kickstart.git"
  },
  "scripts": {
    "build": "bun run build:app",
    "build:app": "bun run prepare:icons && bun run rebuild:native && bun run clean && bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "clean": "rm -rf dist-electron dist-renderer",
    "dev": "bun run prepare:icons && bun run rebuild:native && node scripts/dev-electron.mjs",
    "dev:main": "vite build --watch --config vite.main.config.ts",
    "dev:preload": "vite build --watch --config vite.preload.config.ts",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "lint": "../../node_modules/.bin/oxlint -c ../../.oxlintrc.json src",
    "make": "node ../../scripts/build-desktop-artifact.mjs",
    "package": "node ../../scripts/build-desktop-artifact.mjs",
    "prepare:icons": "node scripts/prepare-icons.mjs",
    "publish": "node ../../scripts/build-desktop-artifact.mjs --publish always",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "rebuild:native:mac": "env SDKROOT=$(xcrun --show-sdk-path) CPLUS_INCLUDE_PATH=$(xcrun --show-sdk-path)/usr/include/c++/v1 electron-rebuild -f -w better-sqlite3,node-pty",
    "start": "bun run build:app && node scripts/start-electron.mjs",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.2",
    "@base-ui/react": "^1.3.0",
    "@base-ui/utils": "^0.2.6",
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/collision": "^0.3.2",
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.1",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/react-dom": "^2.1.8",
    "@floating-ui/utils": "^0.2.11",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@kickstart/assets": "workspace:*",
    "@kickstart/contracts": "workspace:*",
    "@kickstart/core": "workspace:*",
    "png-to-ico": "^2.1.8",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-hotkeys": "^0.4.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "40.8.0",
    "motion": "^12.38.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reselect": "^5.1.1",
    "shadcn": "^4.0.0",
    "tabbable": "^6.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "tw-animate-css": "^1.4.0",
    "use-sync-external-store": "^1.6.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "bindings": "^1.5.0",
    "cmdk": "^1.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.6.2",
    "node-pty": "^1.1.0",
    "react-hook-form": "^7.72.0"
  }
}
